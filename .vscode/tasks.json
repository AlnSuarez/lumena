{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Django dev server",
      "type": "shell",
      "command": ".venv312/bin/python manage.py runserver",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "label": "Backend",
        "group": "lumena",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    
    {
      "label": "Frontend: Next.js dev server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "label": "Frontend",
        "group": "lumena",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Lumena: Start all",
      "dependsOn": [
        "Backend: Django dev server",
        "Frontend: Next.js dev server"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
